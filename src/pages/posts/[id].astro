---
import Layout from "../../layouts/Layout.astro";
import { ReadingProgress } from "../../components/ReadingProgress";
import { FloatingTOC } from "../../components/FloatingTOC";
import { TableOfContents } from "../../components/TableOfContents";
import { Separator } from "../../components/ui/separator";
import { Badge } from "../../components/ui/badge";
import { getBlogPostById, listBlogStaticParams } from "../../lib/blog";
import { extractHeadings } from "../../lib/extract-headings";
import { renderMarkdown } from "../../lib/markdown";

export async function getStaticPaths() {
  const params = await listBlogStaticParams();
  return params.map(({ id }) => ({ params: { id } }));
}

const { id } = Astro.params;
const post = await getBlogPostById(id!);

if (!post) {
  return Astro.redirect("/404");
}

const siteUrl = import.meta.env.SITE ?? "https://daigo-suhara.com";
const headings = extractHeadings(post.body);
const htmlContent = await renderMarkdown(post.body);

const createdAt = new Date(post.publishedAt).toLocaleDateString("ja-JP", {
  year: "numeric",
  month: "long",
  day: "numeric",
});
const updatedAt = new Date(post.updatedAt).toLocaleDateString("ja-JP", {
  year: "numeric",
  month: "long",
  day: "numeric",
});
const isUpdated = post.updatedAt !== post.publishedAt;

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "BlogPosting",
  headline: post.title,
  description: post.excerpt,
  url: `${siteUrl}/posts/${post.id}`,
  datePublished: new Date(post.publishedAt).toISOString(),
  dateModified: new Date(post.updatedAt).toISOString(),
  author: { "@type": "Person", name: "Daigo Suhara", url: siteUrl },
  ...(post.coverImage && { image: post.coverImage }),
  keywords: post.tags.join(", "),
};
---

<Layout
  title={post.title}
  description={post.excerpt}
  ogType="article"
  ogImage={post.coverImage ?? undefined}
  publishedTime={new Date(post.publishedAt).toISOString()}
  modifiedTime={new Date(post.updatedAt).toISOString()}
  keywords={post.tags}
>
  <script is:inline type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
  <ReadingProgress client:load />
  <FloatingTOC headings={headings} client:load />

  <article
    class:list={[
      "mx-auto px-4 sm:px-6 lg:px-8",
      headings.length > 0 ? "max-w-7xl" : "max-w-3xl",
    ]}
  >
    <div
      class:list={[
        headings.length > 0 && "lg:grid lg:grid-cols-[1fr_280px] lg:gap-20",
      ]}
    >
      <!-- Main content -->
      <div class="min-w-0 w-full max-w-3xl mx-auto lg:mx-0">
        <!-- Header -->
        <header class="pt-10 mb-6">
          {post.tags.length > 0 && (
            <div class="flex flex-wrap gap-1.5 mb-8">
              {post.tags.map((tag) => (
                <Badge variant="secondary">{tag}</Badge>
              ))}
            </div>
          )}
          <h1 class="text-3xl sm:text-4xl font-bold tracking-tight leading-tight mb-4">
            {post.title}
          </h1>
          <div class="flex flex-wrap gap-x-4 gap-y-1 text-sm text-muted-foreground">
            <span>
              <span class="mr-1.5">ソース</span>
              <Badge variant="outline" className="ml-0">
                {post.source === "qiita" ? "Qiita" : "Blog"}
              </Badge>
            </span>
            <span>
              <span class="mr-1.5">公開</span>
              <time datetime={post.publishedAt}>{createdAt}</time>
            </span>
            {isUpdated && (
              <span>
                <span class="mr-1.5">更新</span>
                <time datetime={post.updatedAt}>{updatedAt}</time>
              </span>
            )}
            {post.source === "qiita" && (
              <a
                href={post.sourceUrl}
                target="_blank"
                rel="noreferrer noopener"
                class="text-primary underline underline-offset-2"
              >
                元記事を開く
              </a>
            )}
          </div>
        </header>

        <!-- Cover image -->
        {post.coverImage && (
          <div class="relative aspect-video w-full mb-8 overflow-hidden rounded-xl">
            <img
              src={post.coverImage}
              alt={post.title}
              class="w-full h-full object-cover"
              loading="eager"
            />
          </div>
        )}

        <Separator className="mb-8" />

        <!-- Markdown body -->
        <div class="prose-container" set:html={htmlContent} />
      </div>

      <!-- TOC sidebar -->
      {headings.length > 0 && (
        <aside class="hidden lg:block">
          <div class="sticky top-24">
            <TableOfContents headings={headings} client:load />
          </div>
        </aside>
      )}
    </div>
  </article>
</Layout>
