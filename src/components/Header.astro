---
import { ThemeToggle } from "./ThemeToggle";
import { MobileNav } from "./MobileNav";

const pathname = Astro.url.pathname;

const navLinks = [
  { href: "/", label: "HOME" },
  { href: "/works", label: "WORKS" },
  { href: "/blog", label: "BLOG" },
];

---

<header class="sticky top-0 z-50 bg-background/70 backdrop-blur-md border-b border-border/40">
  <div class="px-4 sm:px-6 lg:px-8 h-16 flex items-center justify-between md:grid md:grid-cols-[1fr_auto_1fr]">
    <a
      href="/"
      class="flex items-center gap-2 text-xl hover:opacity-70 transition-opacity whitespace-nowrap"
      style="font-family: var(--font-header)"
    >
      <img src="/loading-icon.png" alt="" class="h-12 w-12 object-contain" aria-hidden="true" />
      Daigo Suhara
    </a>

    <!-- Desktop nav (center) -->
    <nav class="hidden md:flex items-center gap-1 bg-muted/60 border border-border/60 rounded-full px-1.5 py-1.5">
      {navLinks.map(({ href, label }) => {
        const isActive = href === "/" ? pathname === "/" : pathname.startsWith(href);
        return (
          <a
            href={href}
            class:list={[
              "px-4 py-1 rounded-full text-sm transition-all duration-200",
              isActive
                ? "bg-background text-foreground shadow-sm"
                : "text-muted-foreground hover:text-foreground"
            ]}
            style="font-family: var(--font-header)"
          >
            {label}
          </a>
        );
      })}
    </nav>

    <div class="flex items-center gap-2 justify-self-end">
      <!-- Desktop social links -->
      <div class="hidden md:flex items-center gap-1">
        <a
          href="https://github.com/daigo-suhara"
          target="_blank"
          rel="noopener noreferrer"
          aria-label="GitHub"
          class="rounded-full h-8 w-8 flex items-center justify-center hover:bg-accent transition-colors"
        >
          <svg viewBox="0 0 24 24" class="h-4 w-4 fill-current" aria-hidden="true">
            <path d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0 1 12 6.844a9.59 9.59 0 0 1 2.504.337c1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.02 10.02 0 0 0 22 12.017C22 6.484 17.522 2 12 2Z" />
          </svg>
        </a>
        <a
          href="https://x.com/daigo_suhara"
          target="_blank"
          rel="noopener noreferrer"
          aria-label="X"
          class="rounded-full h-8 w-8 flex items-center justify-center hover:bg-accent transition-colors"
        >
          <svg viewBox="0 0 24 24" class="h-4 w-4 fill-current" aria-hidden="true">
            <path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-4.714-6.231-5.401 6.231H2.746l7.73-8.835L1.254 2.25H8.08l4.259 5.632 5.905-5.632Zm-1.161 17.52h1.833L7.084 4.126H5.117z" />
          </svg>
        </a>
      </div>

      <ThemeToggle client:load />
      <MobileNav currentPath={pathname} client:load />
    </div>
  </div>
</header>
